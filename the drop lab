<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Drop Lab — Premium Electronics</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#07070d;--bg2:#0f0f18;--bg3:#171724;--bg4:#1e1e2e;
  --accent:#00d4ff;--accent2:#a855f7;--accent3:#f59e0b;
  --text:#eeeef5;--muted:#666680;--border:rgba(255,255,255,0.07);
  --card:#111120;--red:#ff4466;--green:#00d084;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
h1,h2,h3,h4,.logo,.nav-link{font-family:'Syne',sans-serif;}
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px;}

/* NAV */
nav{position:sticky;top:0;z-index:200;background:rgba(7,7,13,0.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.nav-inner{max-width:1280px;margin:auto;display:flex;align-items:center;justify-content:space-between;height:62px;padding:0 2rem;}
.logo{font-size:1.3rem;font-weight:800;cursor:pointer;letter-spacing:-0.5px;}
.logo .a{color:var(--accent);}
.logo .b{color:var(--text);}
.nav-links{display:flex;gap:.25rem;list-style:none;}
.nav-link{padding:.4rem .9rem;color:var(--muted);font-size:.88rem;font-weight:600;border-radius:8px;cursor:pointer;transition:all .18s;}
.nav-link:hover,.nav-link.active{color:var(--text);background:var(--bg3);}
.nav-right{display:flex;align-items:center;gap:.75rem;}
.cart-btn{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:.4rem .8rem;cursor:pointer;color:var(--text);font-size:.88rem;font-family:'Syne',sans-serif;font-weight:600;display:flex;align-items:center;gap:.4rem;transition:all .18s;}
.cart-btn:hover{border-color:var(--accent);color:var(--accent);}
.cart-count{background:var(--accent);color:#000;font-size:.7rem;font-weight:700;padding:1px 6px;border-radius:20px;}
.admin-btn{background:linear-gradient(135deg,var(--accent2),var(--accent));color:#000;border:none;border-radius:10px;padding:.4rem 1rem;cursor:pointer;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;transition:opacity .18s;}
.admin-btn:hover{opacity:.85;}

/* PAGES */
.page{display:none;animation:fadeIn .3s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* HERO */
.hero{min-height:88vh;display:flex;align-items:center;padding:4rem 2rem;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 700px 500px at 65% 40%,rgba(0,212,255,.06),transparent),radial-gradient(ellipse 500px 400px at 10% 80%,rgba(168,85,247,.05),transparent);}
.hero-grid{max-width:1280px;margin:auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;position:relative;}
.hero-badge{display:inline-flex;align-items:center;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);border-radius:20px;padding:.3rem .85rem;font-size:.78rem;font-weight:600;color:var(--accent);margin-bottom:1.5rem;letter-spacing:.5px;}
.hero h1{font-size:clamp(2.4rem,5vw,3.8rem);font-weight:800;line-height:1.05;letter-spacing:-1.5px;margin-bottom:1.25rem;}
.hero h1 .hl{color:var(--accent);}
.hero p{color:var(--muted);font-size:1rem;line-height:1.7;max-width:440px;margin-bottom:2.5rem;}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-primary{background:var(--accent);color:#000;border:none;border-radius:12px;padding:.72rem 1.6rem;font-family:'Syne',sans-serif;font-weight:700;font-size:.93rem;cursor:pointer;transition:all .18s;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,212,255,.3);}
.btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border);border-radius:12px;padding:.72rem 1.6rem;font-family:'Syne',sans-serif;font-weight:600;font-size:.93rem;cursor:pointer;transition:all .18s;}
.btn-ghost:hover{border-color:rgba(255,255,255,.2);background:var(--bg3);}
.hero-visual{display:flex;align-items:center;justify-content:center;}
.hero-phone{width:240px;height:480px;background:var(--bg3);border-radius:36px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;}
.hero-phone::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 30%,rgba(0,212,255,.08),transparent 60%);}
.phone-screen{width:200px;height:400px;background:var(--bg4);border-radius:24px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem;border:1px solid var(--border);}
.phone-icon{font-size:3.5rem;}
.phone-label{font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:var(--accent);}
.phone-sub{font-size:.78rem;color:var(--muted);}
.stats-row{display:flex;gap:2rem;margin-top:3rem;}
.stat-num{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:var(--accent);}
.stat-label{font-size:.78rem;color:var(--muted);margin-top:.2rem;}

/* SECTION */
.section{padding:5rem 2rem;}
.section-inner{max-width:1280px;margin:auto;}
.section-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;gap:1rem;flex-wrap:wrap;}
.section-title{font-size:clamp(1.6rem,3vw,2.1rem);font-weight:800;letter-spacing:-.5px;}
.section-sub{color:var(--muted);font-size:.88rem;margin-top:.3rem;}
.see-all{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:.4rem .9rem;color:var(--muted);font-size:.83rem;cursor:pointer;font-family:'Syne',sans-serif;font-weight:600;transition:all .18s;white-space:nowrap;}
.see-all:hover{color:var(--text);border-color:rgba(255,255,255,.15);}

/* CATEGORY PILLS */
.categories{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:2rem;}
.cat-pill{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:.38rem .9rem;font-size:.82rem;font-weight:600;font-family:'Syne',sans-serif;cursor:pointer;transition:all .18s;color:var(--muted);}
.cat-pill:hover,.cat-pill.active{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.4);color:var(--accent);}

/* PRODUCT GRID */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:1.2rem;}
.product-card{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden;cursor:pointer;transition:all .22s;position:relative;}
.product-card:hover{border-color:rgba(0,212,255,.25);transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.4);}
.product-img{height:175px;display:flex;align-items:center;justify-content:center;font-size:3.8rem;background:var(--bg3);position:relative;}
.product-badge{position:absolute;top:.6rem;left:.6rem;font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;padding:.2rem .55rem;border-radius:6px;letter-spacing:.5px;}
.product-badge.hot{background:var(--accent3);color:#000;}
.product-badge.new{background:var(--green);color:#000;}
.product-badge.sale{background:var(--red);color:#fff;}
.product-body{padding:1rem 1.1rem 1.2rem;}
.product-cat{font-size:.72rem;color:var(--accent);font-weight:600;letter-spacing:.8px;text-transform:uppercase;margin-bottom:.3rem;}
.product-name{font-family:'Syne',sans-serif;font-size:.97rem;font-weight:700;margin-bottom:.35rem;line-height:1.3;}
.product-desc{font-size:.79rem;color:var(--muted);line-height:1.5;margin-bottom:.8rem;}
.product-footer{display:flex;align-items:center;justify-content:space-between;}
.product-price{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;}
.original{font-size:.78rem;color:var(--muted);text-decoration:line-through;margin-right:.3rem;}
.add-cart{background:var(--accent);color:#000;border:none;border-radius:9px;padding:.38rem .8rem;font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;cursor:pointer;transition:all .18s;}
.add-cart:hover{transform:scale(1.05);}
.add-cart.added{background:var(--green);}

/* PRODUCT DETAIL */
.detail-wrap{max-width:1100px;margin:auto;padding:3rem 2rem;}
.detail-back{display:flex;align-items:center;gap:.5rem;color:var(--muted);cursor:pointer;font-size:.9rem;margin-bottom:2rem;font-family:'Syne',sans-serif;font-weight:600;transition:color .18s;}
.detail-back:hover{color:var(--text);}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;}
.detail-img{background:var(--bg3);border-radius:24px;border:1px solid var(--border);height:380px;display:flex;align-items:center;justify-content:center;font-size:8rem;position:relative;overflow:hidden;}
.detail-img::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 40%,rgba(0,212,255,.07),transparent 60%);}
.detail-info .dcat{font-size:.78rem;color:var(--accent);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:.5rem;}
.detail-info h1{font-size:1.9rem;font-weight:800;letter-spacing:-.5px;margin-bottom:.7rem;line-height:1.2;}
.detail-rating{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;font-size:.85rem;color:var(--muted);}
.stars{color:var(--accent3);}
.detail-price{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent);margin-bottom:1rem;}
.detail-desc{color:var(--muted);line-height:1.7;font-size:.93rem;margin-bottom:1.5rem;}
.detail-specs{background:var(--bg3);border-radius:14px;border:1px solid var(--border);padding:1.2rem;margin-bottom:1.5rem;}
.spec-row{display:flex;justify-content:space-between;padding:.45rem 0;border-bottom:1px solid var(--border);font-size:.86rem;}
.spec-row:last-child{border-bottom:none;}
.spec-key{color:var(--muted);}
.spec-val{font-weight:500;}
.detail-actions{display:flex;gap:.75rem;}
.btn-buy{background:var(--accent);color:#000;border:none;border-radius:12px;padding:.85rem 1.75rem;font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;flex:1;transition:all .18s;}
.btn-buy:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,212,255,.3);}
.btn-wishlist{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:.85rem;cursor:pointer;font-size:1.1rem;transition:all .18s;}
.btn-wishlist:hover{border-color:var(--red);}

/* CART */
.cart-wrap{max-width:880px;margin:auto;padding:3rem 2rem;}
.cart-wrap h2{font-size:1.8rem;font-weight:800;margin-bottom:2rem;}
.cart-empty{text-align:center;padding:4rem;color:var(--muted);}
.cart-empty .eicon{font-size:3.5rem;margin-bottom:1rem;}
.cart-item{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.2rem;display:flex;align-items:center;gap:1.2rem;margin-bottom:.9rem;}
.cart-item-img{width:66px;height:66px;background:var(--bg3);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.9rem;flex-shrink:0;}
.cart-item-info{flex:1;}
.cart-item-name{font-family:'Syne',sans-serif;font-weight:700;margin-bottom:.2rem;font-size:.95rem;}
.cart-item-cat{font-size:.76rem;color:var(--accent);}
.cart-item-price{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:800;}
.cart-qty{display:flex;align-items:center;gap:.45rem;}
.qty-btn{background:var(--bg3);border:1px solid var(--border);border-radius:7px;width:27px;height:27px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1rem;transition:all .18s;}
.qty-btn:hover{border-color:var(--accent);color:var(--accent);}
.qty-num{font-family:'Syne',sans-serif;font-weight:700;width:22px;text-align:center;}
.cart-remove{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.82rem;transition:color .18s;font-family:'Syne',sans-serif;}
.cart-remove:hover{color:var(--red);}
.cart-summary{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;margin-top:1.25rem;}
.summary-row{display:flex;justify-content:space-between;padding:.45rem 0;font-size:.88rem;color:var(--muted);}
.summary-row.total{border-top:1px solid var(--border);margin-top:.5rem;padding-top:.9rem;font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--text);}
.checkout-btn{background:var(--accent);color:#000;border:none;border-radius:12px;padding:.9rem;width:100%;font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;cursor:pointer;margin-top:1.2rem;transition:all .18s;}
.checkout-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,212,255,.3);}

/* CHECKOUT */
.checkout-wrap{max-width:1000px;margin:auto;padding:3rem 2rem;}
.checkout-wrap h2{font-size:1.8rem;font-weight:800;margin-bottom:2rem;}
.checkout-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:2rem;align-items:start;}
.form-section{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:1.5rem;margin-bottom:1.2rem;}
.form-section h3{font-size:.97rem;font-weight:700;margin-bottom:1.2rem;color:var(--accent);}
.form-group{margin-bottom:.9rem;}
.form-group label{display:block;font-size:.78rem;color:var(--muted);margin-bottom:.35rem;font-weight:500;}
.form-group input,.form-group select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:.62rem .88rem;color:var(--text);font-size:.88rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .18s;}
.form-group input:focus,.form-group select:focus{border-color:var(--accent);}
.form-group select option{background:var(--bg3);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;}
.order-summary-box{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:1.4rem;position:sticky;top:80px;}
.order-summary-box h3{font-size:.97rem;font-weight:700;margin-bottom:1.2rem;color:var(--accent);}
.order-item{display:flex;align-items:center;gap:.7rem;padding:.55rem 0;border-bottom:1px solid var(--border);}
.order-item:last-of-type{border-bottom:none;}
.order-item-img{width:42px;height:42px;background:var(--bg3);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;}
.order-item-name{flex:1;font-size:.85rem;font-weight:500;}
.order-item-price{font-family:'Syne',sans-serif;font-size:.88rem;font-weight:700;}
.pay-icons{display:flex;gap:.4rem;margin-top:.9rem;flex-wrap:wrap;}
.pay-icon{background:var(--bg3);border:1px solid var(--border);border-radius:7px;padding:.35rem .65rem;font-size:.73rem;color:var(--muted);font-weight:600;}
.place-order-btn{background:linear-gradient(135deg,var(--accent2),var(--accent));color:#fff;border:none;border-radius:12px;padding:.9rem;width:100%;font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;cursor:pointer;margin-top:1.2rem;transition:opacity .18s;}
.place-order-btn:hover{opacity:.88;}

/* ABOUT */
.about-hero{padding:5rem 2rem;text-align:center;position:relative;overflow:hidden;}
.about-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 600px 400px at 50% 50%,rgba(168,85,247,.06),transparent);}
.about-hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:800;letter-spacing:-1px;margin-bottom:1rem;position:relative;}
.about-hero p{color:var(--muted);font-size:1rem;max-width:540px;margin:auto;line-height:1.7;position:relative;}
.about-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.2rem;max-width:1000px;margin:3.5rem auto;padding:0 2rem;}
.about-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:1.6rem;}
.about-icon{font-size:2.2rem;margin-bottom:.9rem;}
.about-card h3{font-size:.97rem;font-weight:700;margin-bottom:.45rem;}
.about-card p{font-size:.85rem;color:var(--muted);line-height:1.6;}

/* SUCCESS */
.success-wrap{text-align:center;padding:6rem 2rem;}
.success-icon{font-size:4.5rem;margin-bottom:1.4rem;}
.success-wrap h2{font-size:2rem;font-weight:800;margin-bottom:.7rem;}
.success-wrap p{color:var(--muted);margin-bottom:2rem;}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:3rem 2rem;margin-top:3rem;}
.footer-inner{max-width:1280px;margin:auto;display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:3rem;}
.footer-brand p{color:var(--muted);font-size:.85rem;line-height:1.6;margin-top:.7rem;}
.footer-col h4{font-size:.88rem;font-weight:700;margin-bottom:.9rem;}
.footer-col a{display:block;color:var(--muted);font-size:.83rem;text-decoration:none;margin-bottom:.45rem;transition:color .18s;cursor:pointer;}
.footer-col a:hover{color:var(--text);}
.footer-bottom{max-width:1280px;margin:2rem auto 0;border-top:1px solid var(--border);padding-top:1.4rem;display:flex;justify-content:space-between;color:var(--muted);font-size:.8rem;}

/* ADMIN LOGIN */
.login-overlay{position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.88);backdrop-filter:blur(14px);display:flex;align-items:center;justify-content:center;padding:1rem;}
.login-overlay.hidden{display:none;}
.login-box{background:var(--bg2);border:1px solid rgba(168,85,247,.35);border-radius:24px;padding:2.5rem 2rem;width:100%;max-width:370px;text-align:center;}
.login-icon-big{font-size:2.4rem;margin-bottom:1rem;}
.login-box h2{font-size:1.25rem;font-weight:800;margin-bottom:.35rem;}
.login-sub{font-size:.82rem;color:var(--muted);margin-bottom:1.75rem;}
.login-field{text-align:left;margin-bottom:.9rem;}
.login-field label{display:block;font-size:.78rem;color:var(--muted);margin-bottom:.35rem;font-weight:500;}
.login-field input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:.62rem .88rem;color:var(--text);font-size:.9rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .18s;}
.login-field input:focus{border-color:var(--accent2);}
.login-error{background:rgba(255,68,102,.1);border:1px solid rgba(255,68,102,.3);border-radius:9px;padding:.5rem .85rem;font-size:.82rem;color:var(--red);margin-bottom:.9rem;display:none;text-align:left;}
.login-submit{background:linear-gradient(135deg,var(--accent2),var(--accent));color:#fff;border:none;border-radius:12px;padding:.82rem;width:100%;font-family:'Syne',sans-serif;font-weight:800;font-size:.93rem;cursor:pointer;transition:opacity .18s;margin-top:.5rem;}
.login-submit:hover{opacity:.85;}
.login-cancel{background:none;border:none;color:var(--muted);font-size:.82rem;cursor:pointer;margin-top:.85rem;font-family:'DM Sans',sans-serif;transition:color .18s;display:block;width:100%;padding:.4rem;}
.login-cancel:hover{color:var(--text);}

/* ADMIN PANEL */
.admin-overlay{position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.72);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:1rem;}
.admin-overlay.hidden{display:none;}
.admin-modal{background:var(--bg2);border:1px solid rgba(168,85,247,.3);border-radius:24px;width:100%;max-width:820px;max-height:90vh;overflow:hidden;display:flex;flex-direction:column;}
.admin-header{background:linear-gradient(135deg,rgba(168,85,247,.13),rgba(0,212,255,.08));border-bottom:1px solid var(--border);padding:1.2rem 1.6rem;display:flex;align-items:center;justify-content:space-between;}
.admin-header h2{font-size:1.1rem;font-weight:800;}
.admin-header-right{display:flex;gap:.5rem;align-items:center;}
.logout-btn{background:rgba(255,68,102,.12);border:1px solid rgba(255,68,102,.3);border-radius:9px;padding:.3rem .75rem;color:var(--red);font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;cursor:pointer;transition:all .18s;}
.logout-btn:hover{background:rgba(255,68,102,.2);}
.admin-close{background:var(--bg3);border:1px solid var(--border);border-radius:9px;width:32px;height:32px;cursor:pointer;color:var(--muted);font-size:1.1rem;display:flex;align-items:center;justify-content:center;transition:all .18s;}
.admin-close:hover{color:var(--red);border-color:var(--red);}
.admin-tabs{display:flex;border-bottom:1px solid var(--border);}
.admin-tab{padding:.7rem 1.4rem;font-family:'Syne',sans-serif;font-weight:700;font-size:.83rem;cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;transition:all .18s;}
.admin-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.admin-body{flex:1;overflow-y:auto;padding:1.4rem;}
.admin-hint{font-size:.8rem;color:var(--muted);margin-bottom:1.1rem;}
.admin-product-row{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:.85rem 1rem;display:flex;align-items:center;gap:.9rem;margin-bottom:.6rem;transition:border-color .18s;}
.admin-product-row:hover{border-color:rgba(255,255,255,.12);}
.admin-prod-icon{width:42px;height:42px;background:var(--bg4);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;}
