  prevPage = active ? active.id.replace("page-", "") : "home";
  showPage(id);
  var links = document.querySelectorAll(".nav-link");
  for (var i = 0; i < links.length; i++) links[i].classList.remove("active");
  if (el) el.classList.add("active");
  if (id === "products") renderAllProducts();
  if (id === "cart") renderCart();
  if (id === "checkout") renderCheckout();
}

function showPrevPage() { showPage(prevPage || "products"); }

function renderCard(p) {
  var orig = p.original ? '<span class="original">&#8377;' + p.original.toLocaleString("en-IN") + "</span>" : "";
  var badge = p.badge ? '<div class="product-badge ' + p.badge + '">' + p.badge.toUpperCase() + "</div>" : "";
  return '<div class="product-card" onclick="openProduct(' + p.id + ')">' +
    '<div class="product-img">' + badge + p.emoji + "</div>" +
    '<div class="product-body">' +
    '<div class="product-cat">' + p.cat + "</div>" +
    '<div class="product-name">' + p.name + "</div>" +
    '<div class="product-desc">' + p.desc.substring(0, 72) + "...</div>" +
    '<div class="product-footer">' +
    '<div class="product-price">' + orig + "&#8377;" + p.price.toLocaleString("en-IN") + "</div>" +
    '<button class="add-cart" onclick="event.stopPropagation();addToCart(' + p.id + ',this)">+ Add</button>' +
    "</div></div></div>";
}

function renderFeatured() {
  var el = document.getElementById("featuredGrid");
  if (!el) return;
  var html = "";
  var limit = Math.min(8, products.length);
  for (var i = 0; i < limit; i++) html += renderCard(products[i]);
  el.innerHTML = html;
}

var activeCategory = "All";

function renderCategories() {
  var cats = ["All"];
  for (var i = 0; i < products.length; i++) {
    if (cats.indexOf(products[i].cat) === -1) cats.push(products[i].cat);
  }
  var html = "";
  for (var j = 0; j < cats.length; j++) {
    html += '<div class="cat-pill' + (cats[j] === activeCategory ? " active" : "") + '" onclick="filterCat(\'' + cats[j] + '\',this)">' + cats[j] + "</div>";
  }
  document.getElementById("categoryPills").innerHTML = html;
}

function filterCat(cat, el) {
  activeCategory = cat;
  var pills = document.querySelectorAll(".cat-pill");
  for (var i = 0; i < pills.length; i++) pills[i].classList.remove("active");
  el.classList.add("active");
  renderAllProducts();
}

function renderAllProducts() {
  renderCategories();
  var filtered = [];
  for (var i = 0; i < products.length; i++) {
    if (activeCategory === "All" || products[i].cat === activeCategory) filtered.push(products[i]);
  }
  document.getElementById("productCount").textContent = filtered.length + " product" + (filtered.length !== 1 ? "s" : "");
  var html = "";
  for (var j = 0; j < filtered.length; j++) html += renderCard(filtered[j]);
  document.getElementById("allProductsGrid").innerHTML = html;
}

function openProduct(id) {
  var active = document.querySelector(".page.active");
  prevPage = active ? active.id.replace("page-", "") : "home";
  var p = null;
  for (var i = 0; i < products.length; i++) { if (products[i].id === id) { p = products[i]; break; } }
  if (!p) return;
  document.getElementById("detailImg").innerHTML = '<span style="font-size:7rem;position:relative;z-index:1;">' + p.emoji + "</span>";
  document.getElementById("detailCat").textContent = p.cat;
  document.getElementById("detailName").textContent = p.name;
  document.getElementById("detailRating").textContent = p.rating;
  document.getElementById("detailPrice").textContent = "₹" + p.price.toLocaleString("en-IN");
  document.getElementById("detailDesc").textContent = p.desc;
  var keys = Object.keys(p.specs);
  var specs = "";
  for (var j = 0; j < keys.length; j++) {
    specs += '<div class="spec-row"><span class="spec-key">' + keys[j].replace(/_/g, " ") + '</span><span class="spec-val">' + p.specs[keys[j]] + "</span></div>";
  }
  document.getElementById("detailSpecs").innerHTML = specs;
  (function(pid) {
    document.getElementById("detailAddCart").onclick = function() { addToCart(pid, document.getElementById("detailAddCart")); };
  })(id);
  showPage("detail");
}

function addToCart(id, btn) {
  var p = null;
  for (var i = 0; i < products.length; i++) { if (products[i].id === id) { p = products[i]; break; } }
  if (!p) return;
  var found = false;
  for (var j = 0; j < cart.length; j++) { if (cart[j].id === id) { cart[j].qty++; found = true; break; } }
  if (!found) cart.push({id: p.id, name: p.name, cat: p.cat, price: p.price, emoji: p.emoji, qty: 1});
  updateCartCount();
  btn.textContent = "✓ Added";
  btn.classList.add("added");
  setTimeout(function() { btn.textContent = "+ Add"; btn.classList.remove("added"); }, 1200);
  showToast(p.name + " added to cart!");
}

function updateCartCount() {
  var total = 0;
  for (var i = 0; i < cart.length; i++) total += cart[i].qty;
  document.getElementById("cartCount").textContent = total;
}

function renderCart() {
  var el = document.getElementById("cartItems");
  var sumEl = document.getElementById("cartSummary");
  if (cart.length === 0) {
    el.innerHTML = '<div class="cart-empty"><div class="eicon">🛒</div><p style="margin-top:.5rem">Your cart is empty</p></div>';
    sumEl.innerHTML = "";
    return;
  }
  var html = "";
  for (var i = 0; i < cart.length; i++) {
    var item = cart[i];
    html += '<div class="cart-item">' +
      '<div class="cart-item-img">' + item.emoji + "</div>" +
      '<div class="cart-item-info"><div class="cart-item-name">' + item.name + '</div><div class="cart-item-cat">' + item.cat + "</div></div>" +
      '<div class="cart-qty">' +
      '<div class="qty-btn" onclick="changeQty(' + item.id + ',-1)">&#8722;</div>' +
      '<div class="qty-num">' + item.qty + "</div>" +
      '<div class="qty-btn" onclick="changeQty(' + item.id + ',1)">+</div>' +
      "</div>" +
      '<div class="cart-item-price">&#8377;' + (item.price * item.qty).toLocaleString("en-IN") + "</div>" +
      '<button class="cart-remove" onclick="removeCart(' + item.id + ')">Remove</button>' +
      "</div>";
  }
  el.innerHTML = html;
  var subtotal = 0;
  for (var j = 0; j < cart.length; j++) subtotal += cart[j].price * cart[j].qty;
  var gst = Math.round(subtotal * 0.18);
  var total = subtotal + gst;
  sumEl.innerHTML = '<div class="cart-summary">' +
    '<div class="summary-row"><span>Subtotal</span><span>&#8377;' + subtotal.toLocaleString("en-IN") + "</span></div>" +
    '<div class="summary-row"><span>Shipping</span><span style="color:var(--green)">FREE</span></div>' +
    '<div class="summary-row"><span>GST (18%)</span><span>&#8377;' + gst.toLocaleString("en-IN") + "</span></div>" +
    '<div class="summary-row total"><span>Total</span><span>&#8377;' + total.toLocaleString("en-IN") + "</span></div>" +
    '<button class="checkout-btn" onclick="navTo(\'checkout\',null)">Proceed to Checkout &rarr;</button>' +
    "</div>";
}

function changeQty(id, delta) {
  for (var i = 0; i < cart.length; i++) {
    if (cart[i].id === id) {
      cart[i].qty += delta;
      if (cart[i].qty <= 0) cart.splice(i, 1);
      break;
    }
  }
  updateCartCount();
  renderCart();
}

function removeCart(id) {
  cart = cart.filter(function(x) { return x.id !== id; });
  updateCartCount();
  renderCart();
}

function renderCheckout() {
  var el = document.getElementById("checkoutItems");
  var html = "";
  for (var i = 0; i < cart.length; i++) {
    var item = cart[i];
    html += '<div class="order-item">' +
      '<div class="order-item-img">' + item.emoji + "</div>" +
      '<div class="order-item-name">' + item.name + " &times; " + item.qty + "</div>" +
      '<div class="order-item-price">&#8377;' + (item.price * item.qty).toLocaleString("en-IN") + "</div>" +
      "</div>";
  }
  el.innerHTML = html;
  var subtotal = 0;
  for (var j = 0; j < cart.length; j++) subtotal += cart[j].price * cart[j].qty;
  var gst = Math.round(subtotal * 0.18);
  document.getElementById("chkSubtotal").textContent = "₹" + subtotal.toLocaleString("en-IN");
  document.getElementById("chkGst").textContent = "₹" + gst.toLocaleString("en-IN");
  document.getElementById("chkTotal").textContent = "₹" + (subtotal + gst).toLocaleString("en-IN");
}

function togglePayFields() {
  var m = document.getElementById("payMethod").value;
  document.getElementById("cardFields").style.display = m === "card" ? "block" : "none";
  document.getElementById("upiField").style.display = m === "upi" ? "block" : "none";
}

function placeOrder() {
  cart = [];
  updateCartCount();
  showPage("success");
}

/* ADMIN LOGIN */
var ADMIN_USER = "admin";
var ADMIN_PASS = "droplab2024";
var adminLoggedIn = false;

function openAdmin() {
  if (adminLoggedIn) { showAdminPanel(); return; }
  document.getElementById("loginOverlay").classList.remove("hidden");
  document.getElementById("loginUser").value = "";
  document.getElementById("loginPass").value = "";
  document.getElementById("loginError").style.display = "none";
  setTimeout(function() { document.getElementById("loginUser").focus(); }, 120);
}

function closeLogin() {
  document.getElementById("loginOverlay").classList.add("hidden");
}

function doLogin() {
  var u = document.getElementById("loginUser").value.trim();
  var p = document.getElementById("loginPass").value;
  if (u === ADMIN_USER && p === ADMIN_PASS) {
    adminLoggedIn = true;
    closeLogin();
    showAdminPanel();
    showToast("Welcome back, Admin!");
  } else {
    document.getElementById("loginError").style.display = "block";
    document.getElementById("loginPass").value = "";
    document.getElementById("loginPass").focus();
  }
}

function showAdminPanel() {
  document.getElementById("adminOverlay").classList.remove("hidden");
  renderAdminList();
  renderEmojiPicker();
}

function closeAdmin() {
  document.getElementById("adminOverlay").classList.add("hidden");
}

function logoutAdmin() {
  adminLoggedIn = false;
  closeAdmin();
  showToast("Logged out successfully.");
}

/* ADMIN PANEL */
var emojis = ["📱","💻","🎧","🔊","📷","🚁","🎮","⌚","📺","🖱️","⌨️","🔋","💡","📡","🖥️","🎵","🔭","🎙️","📻","🕹️","📦"];

function adminTab(tab, el) {
  var tabs = document.querySelectorAll(".admin-tab");
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove("active");
  el.classList.add("active");
  document.getElementById("adminManage").style.display = tab === "manage" ? "block" : "none";
  document.getElementById("adminAdd").style.display = tab === "add" ? "block" : "none";
}

function renderAdminList() {
  var html = "";
  for (var i = 0; i < products.length; i++) {
    var p = products[i];
    html += '<div class="admin-product-row">' +
      '<div class="admin-prod-icon">' + p.emoji + "</div>" +
      '<div class="admin-prod-info"><div class="admin-prod-name">' + p.name + '</div><div class="admin-prod-cat">' + p.cat + "</div></div>" +
      '<input class="admin-price-input" id="price_' + p.id + '" value="' + p.price + '" type="number" min="1">' +
      '<button class="save-price-btn" onclick="savePrice(' + p.id + ')">Save</button>' +
      '<button class="del-btn" onclick="deleteProduct(' + p.id + ')" title="Delete">🗑</button>' +
      "</div>";
  }
  document.getElementById("adminProductList").innerHTML = html;
}

function savePrice(id) {
  var input = document.getElementById("price_" + id);
  var val = parseInt(input.value);
  if (isNaN(val) || val <= 0) { showToast("Enter a valid price!", "error"); return; }
  for (var i = 0; i < products.length; i++) {
    if (products[i].id === id) { products[i].price = val; break; }
  }
  showToast("Price updated to ₹" + val.toLocaleString("en-IN") + "!");
  renderFeatured();
  var pp = document.getElementById("page-products");
  if (pp && pp.classList.contains("active")) renderAllProducts();
}

function deleteProduct(id) {
  if (!confirm("Delete this product? This cannot be undone.")) return;
  products = products.filter(function(p) { return p.id !== id; });
  cart = cart.filter(function(c) { return c.id !== id; });
  updateCartCount();
  renderAdminList();
  renderFeatured();
  showToast("Product deleted.");
}

function renderEmojiPicker() {
  var selected = document.getElementById("newEmoji").value || "📦";
  var html = "";
  for (var i = 0; i < emojis.length; i++) {
    html += '<span class="emoji-opt' + (emojis[i] === selected ? " selected" : "") + '" onclick="selectEmoji(\'' + emojis[i] + '\',this)">' + emojis[i] + "</span>";
  }
  document.getElementById("emojiPicker").innerHTML = html;
}

function selectEmoji(e, el) {
  document.getElementById("newEmoji").value = e;
  var opts = document.querySelectorAll(".emoji-opt");
  for (var i = 0; i < opts.length; i++) opts[i].classList.remove("selected");
  el.classList.add("selected");
}

function addProduct() {
  var name = document.getElementById("newName").value.trim();
  var cat = document.getElementById("newCat").value;
  var price = parseInt(document.getElementById("newPrice").value);
  var origVal = parseInt(document.getElementById("newOriginal").value);
  var original = isNaN(origVal) ? null : origVal;
  var desc = document.getElementById("newDesc").value.trim();
  var emoji = document.getElementById("newEmoji").value || "📦";
  var badge = document.getElementById("newBadge").value;
  var rating = document.getElementById("newRating").value;
  if (!name || !desc || isNaN(price) || price <= 0) {
    showToast("Please fill all required fields!", "error");
    return;
  }
  products.unshift({id: Date.now(), name: name, cat: cat, price: price, original: original, desc: desc, emoji: emoji, badge: badge, rating: rating, specs: {Category: cat, Price: "₹" + price.toLocaleString("en-IN")}});
  document.getElementById("newName").value = "";
  document.getElementById("newPrice").value = "";
  document.getElementById("newOriginal").value = "";
  document.getElementById("newDesc").value = "";
  document.getElementById("newEmoji").value = "📦";
  document.getElementById("newBadge").value = "";
  renderFeatured();
  renderAdminList();
  renderEmojiPicker();
  adminTab("manage", document.getElementById("tabManage"));
  showToast(name + " added to the store!");
}

function showToast(msg, type) {
  var t = document.getElementById("toast");
  t.textContent = msg;
  t.className = "toast show" + (type ? " " + type : "");
  setTimeout(function() { t.className = "toast"; }, 2800);
}

renderFeatured();
</script>
